#!/usr/bin/env python3
"""
voice-ingest — capture human messages into voice.db with Gemini embeddings.

Usage:
  voice-ingest --human-id <id> --channel <ch> --message <text>
  voice-ingest --human-id <id> --channel <ch> --from-stdin
  voice-ingest --human-id <id> --channel <ch> --batch <file.jsonl>
"""

import argparse
import json
import os
import sqlite3
import struct
import sys
import urllib.request
import urllib.error
import uuid
from datetime import datetime, timezone
from pathlib import Path

# ── Paths ─────────────────────────────────────────────────────────────────────

STATE_DIR = Path(os.environ.get("MINICLAW_STATE_DIR", os.environ.get("OPENCLAW_STATE_DIR", Path.home() / ".openclaw")))
BOT_DIR = STATE_DIR / "user" / "augmentedmike_bot"
DB_PATH = BOT_DIR / "voice" / "voice.db"
LOG_PATH = STATE_DIR / "logs" / "voice-ingest.log"

GEMINI_API_KEY = os.environ.get("GOOGLE_API_KEY", "")
GEMINI_EMBED_URL = (
    "https://generativelanguage.googleapis.com/v1beta/models/"
    "gemini-embedding-001:embedContent?key={key}"
)

# Valid channel values per the DB schema CHECK constraint
VALID_CHANNELS = {"telegram", "inbox", "claude-code", "other"}


# ── Logging ───────────────────────────────────────────────────────────────────

def log(msg: str) -> None:
    ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    line = f"{ts} {msg}\n"
    try:
        LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with open(LOG_PATH, "a") as f:
            f.write(line)
    except Exception:
        pass


def normalize_channel(channel: str) -> str:
    c = channel.lower().strip()
    if c in VALID_CHANNELS:
        return c
    # Map common aliases
    if c in ("tg", "tgram"):
        return "telegram"
    if c in ("cc", "code", "session"):
        return "claude-code"
    return "other"


# ── DB setup ──────────────────────────────────────────────────────────────────

def open_db(path: Path = DB_PATH) -> sqlite3.Connection:
    path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(path))
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA synchronous=NORMAL")
    conn.execute("PRAGMA foreign_keys=ON")

    # Create tables if not yet present (migration script may have done this already)
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS voice_settings (
            human_id                       TEXT PRIMARY KEY,
            opted_out                      INTEGER NOT NULL DEFAULT 0 CHECK(opted_out IN (0,1)),
            opted_out_at                   TEXT,
            learning_active                INTEGER NOT NULL DEFAULT 1 CHECK(learning_active IN (0,1)),
            last_analyzed_at               TEXT,
            message_count_at_last_analysis INTEGER NOT NULL DEFAULT 0,
            updated_at                     TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))
        );

        CREATE TABLE IF NOT EXISTS human_voice (
            id         TEXT PRIMARY KEY,
            human_id   TEXT NOT NULL,
            channel    TEXT NOT NULL CHECK(channel IN ('telegram','inbox','claude-code','other')),
            message    TEXT NOT NULL,
            embedding  BLOB,
            sent_at    TEXT NOT NULL,
            opted_out  INTEGER NOT NULL DEFAULT 0 CHECK(opted_out IN (0,1)),
            created_at TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))
        );

        CREATE INDEX IF NOT EXISTS idx_voice_human_id   ON human_voice(human_id);
        CREATE INDEX IF NOT EXISTS idx_voice_channel    ON human_voice(channel);
        CREATE INDEX IF NOT EXISTS idx_voice_sent_at    ON human_voice(sent_at);
        CREATE INDEX IF NOT EXISTS idx_voice_opted_out  ON human_voice(opted_out);
    """)
    conn.commit()

    # Add columns that may be missing from older DBs (idempotent)
    for ddl in [
        "ALTER TABLE voice_settings ADD COLUMN message_count_at_last_analysis INTEGER NOT NULL DEFAULT 0",
        "ALTER TABLE voice_settings ADD COLUMN needs_disclosure INTEGER NOT NULL DEFAULT 0",
        "ALTER TABLE voice_settings ADD COLUMN disclosed_at TEXT",
    ]:
        try:
            conn.execute(ddl)
            conn.commit()
        except Exception:
            pass  # column already exists

    # Backfill FTS for any rows not yet indexed (idempotent one-time repair)
    conn.execute("""
        INSERT INTO voice_fts (voice_id, human_id, message)
        SELECT id, human_id, message FROM human_voice h
        WHERE NOT EXISTS (
            SELECT 1 FROM voice_fts f WHERE f.voice_id = h.id
        )
    """)
    conn.commit()

    return conn


# ── Opt-out check ─────────────────────────────────────────────────────────────

def is_opted_out(conn: sqlite3.Connection, human_id: str) -> bool:
    row = conn.execute(
        "SELECT opted_out FROM voice_settings WHERE human_id = ?", (human_id,)
    ).fetchone()
    return bool(row and row["opted_out"])


# ── Gemini embedding ──────────────────────────────────────────────────────────

def _resolve_api_key() -> str:
    key = GEMINI_API_KEY
    if key:
        return key
    vault_bin = STATE_DIR / "miniclaw" / "system" / "bin" / "mc-vault"
    if vault_bin.exists():
        import subprocess
        result = subprocess.run(
            [str(vault_bin), "get", "gemini-api-key"],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            line = result.stdout.strip()
            if " = " in line:
                return line.split(" = ", 1)[1]
    return ""


def embed(text: str) -> bytes | None:
    api_key = _resolve_api_key()
    if not api_key:
        log("ERROR embed: no GOOGLE_API_KEY available, skipping embedding")
        return None

    url = GEMINI_EMBED_URL.format(key=api_key)
    payload = json.dumps({
        "content": {"parts": [{"text": text}]}
    }).encode("utf-8")

    req = urllib.request.Request(
        url,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        values: list[float] = data["embedding"]["values"]
        # Pack as little-endian float32 BLOB for sqlite-vec compatibility
        return struct.pack(f"<{len(values)}f", *values)
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        log(f"ERROR embed HTTP {e.code}: {body[:200]}")
        return None
    except Exception as exc:
        log(f"ERROR embed: {exc}")
        return None


# ── Store message ─────────────────────────────────────────────────────────────

def store(
    conn: sqlite3.Connection,
    human_id: str,
    channel: str,
    message_text: str,
    sent_at: str | None = None,
) -> str:
    embedding_blob = embed(message_text)
    row_id = str(uuid.uuid4())
    if sent_at is None:
        sent_at = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    conn.execute(
        """
        INSERT INTO human_voice (id, human_id, channel, message, embedding, sent_at)
        VALUES (?, ?, ?, ?, ?, ?)
        """,
        (row_id, human_id, channel, message_text, embedding_blob, sent_at),
    )
    # Keep FTS5 table in sync — insert alongside every human_voice row
    conn.execute(
        "INSERT INTO voice_fts (voice_id, human_id, message) VALUES (?, ?, ?)",
        (row_id, human_id, message_text),
    )
    conn.commit()
    log(
        f"ingested id={row_id[:8]} human={human_id} channel={channel} "
        f"len={len(message_text)} embed={'yes' if embedding_blob else 'no'}"
    )
    return row_id


# ── Ingest one message ────────────────────────────────────────────────────────

def needs_disclosure_flag(conn: sqlite3.Connection, human_id: str) -> bool:
    """Return True if this human is new and hasn't received a disclosure yet."""
    row = conn.execute(
        "SELECT disclosed_at, needs_disclosure FROM voice_settings WHERE human_id = ?",
        (human_id,)
    ).fetchone()
    if row is None:
        # New human — check if they have any prior messages (could happen if DB was partially set up)
        msg_count = conn.execute(
            "SELECT COUNT(*) AS c FROM human_voice WHERE human_id = ?", (human_id,)
        ).fetchone()["c"]
        if msg_count > 0:
            return False  # has prior messages, no need to disclose retroactively
        return True  # brand new — needs disclosure
    if row["disclosed_at"]:
        return False  # already disclosed
    if row["needs_disclosure"]:
        return False  # already queued (set on a previous ingest call)
    # Settings row exists but no messages yet ingested → needs disclosure
    msg_count = conn.execute(
        "SELECT COUNT(*) AS c FROM human_voice WHERE human_id = ?", (human_id,)
    ).fetchone()["c"]
    return msg_count == 0  # only trigger on very first message


def set_needs_disclosure(conn: sqlite3.Connection, human_id: str) -> None:
    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    conn.execute(
        """
        INSERT INTO voice_settings (human_id, needs_disclosure, updated_at)
        VALUES (?, 1, ?)
        ON CONFLICT(human_id) DO UPDATE SET
            needs_disclosure = 1,
            updated_at = excluded.updated_at
        WHERE disclosed_at IS NULL AND needs_disclosure = 0
        """,
        (human_id, now),
    )
    conn.commit()
    log(f"needs_disclosure set for human={human_id}")


def _get_new_message_count(conn: sqlite3.Connection, human_id: str) -> int:
    """Return count of messages since last analysis for this human."""
    total = conn.execute(
        "SELECT COUNT(*) FROM human_voice WHERE human_id = ? AND opted_out = 0",
        (human_id,),
    ).fetchone()[0]
    at_last = conn.execute(
        "SELECT COALESCE(message_count_at_last_analysis, 0) FROM voice_settings WHERE human_id = ?",
        (human_id,),
    ).fetchone()
    last = at_last[0] if at_last else 0
    return total - last


def _maybe_trigger_analyze(human_id: str, threshold: int = 50) -> None:
    """Spawn voice-analyze in the background if new messages >= threshold."""
    import subprocess
    analyze_bin = STATE_DIR / "miniclaw" / "system" / "bin" / "voice-analyze"
    if not analyze_bin.exists():
        log(f"WARN: voice-analyze not found at {analyze_bin}, skipping trigger")
        return
    log(f"50-msg threshold reached for human={human_id}, spawning voice-analyze")
    subprocess.Popen(
        [str(analyze_bin), "--human-id", human_id],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def ingest_one(
    conn: sqlite3.Connection,
    human_id: str,
    channel: str,
    text: str,
    sent_at: str | None = None,
) -> None:
    text = text.strip()
    if not text:
        return
    if is_opted_out(conn, human_id):
        log(f"skip opted_out human={human_id}")
        return
    # Flag disclosure on first-ever message for this human
    if needs_disclosure_flag(conn, human_id):
        set_needs_disclosure(conn, human_id)
    channel = normalize_channel(channel)
    store(conn, human_id, channel, text, sent_at)
    # Trigger analysis when 50+ new messages have accumulated
    new_count = _get_new_message_count(conn, human_id)
    if new_count >= 50:
        _maybe_trigger_analyze(human_id)


# ── Batch ingest ──────────────────────────────────────────────────────────────

def ingest_batch(conn: sqlite3.Connection, human_id: str, channel: str, filepath: str) -> int:
    count = 0
    with open(filepath, "r", encoding="utf-8") as f:
        for lineno, raw in enumerate(f, 1):
            raw = raw.strip()
            if not raw:
                continue
            try:
                record = json.loads(raw)
            except json.JSONDecodeError:
                log(f"WARN batch line {lineno}: not valid JSON, skipping")
                continue

            text = record.get("message") or record.get("text") or record.get("content", "")
            if not text:
                log(f"WARN batch line {lineno}: no message/text/content field, skipping")
                continue

            # sent_at from ts/timestamp (unix epoch) or iso string
            sent_at: str | None = None
            raw_ts = record.get("ts") or record.get("timestamp") or record.get("sent_at")
            if raw_ts:
                if isinstance(raw_ts, (int, float)):
                    sent_at = datetime.fromtimestamp(raw_ts, tz=timezone.utc).strftime(
                        "%Y-%m-%dT%H:%M:%SZ"
                    )
                elif isinstance(raw_ts, str):
                    sent_at = raw_ts

            h_id = record.get("human_id", human_id)
            ch = normalize_channel(record.get("channel", channel))

            if is_opted_out(conn, h_id):
                log(f"skip opted_out human={h_id} (batch line {lineno})")
                continue

            store(conn, h_id, ch, text, sent_at)
            count += 1
    return count


# ── Embedding backfill ────────────────────────────────────────────────────────

def backfill_embeddings(conn: sqlite3.Connection) -> tuple[int, int]:
    """Embed all human_voice rows that have NULL embeddings. Returns (done, failed)."""
    rows = conn.execute(
        "SELECT id, message FROM human_voice WHERE embedding IS NULL ORDER BY sent_at"
    ).fetchall()
    done = 0
    failed = 0
    for row in rows:
        blob = embed(row["message"])
        if blob:
            conn.execute(
                "UPDATE human_voice SET embedding = ? WHERE id = ?",
                (blob, row["id"]),
            )
            conn.commit()
            log(f"backfill embed id={row['id'][:8]} ok ({len(blob)} bytes)")
            done += 1
        else:
            log(f"backfill embed id={row['id'][:8]} FAILED (no blob)")
            failed += 1
    return done, failed


# ── CLI ───────────────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="voice-ingest",
        description="Capture human messages into voice.db with Gemini embeddings.",
    )
    parser.add_argument(
        "--human-id", default="augmentedmike",
        help="Human identifier (default: augmentedmike)"
    )
    parser.add_argument(
        "--channel", default="other",
        help="Channel: telegram | inbox | claude-code | other"
    )
    parser.add_argument("--message", "-m", help="Message text (single ingest)")
    parser.add_argument("--from-stdin", action="store_true", help="Read message from stdin")
    parser.add_argument("--batch", metavar="FILE", help="Batch ingest from JSONL file")
    parser.add_argument("--backfill-embeddings", action="store_true",
                        help="Compute and store embeddings for all rows with NULL embedding")
    parser.add_argument("--db", help=f"Override DB path (default: {DB_PATH})")

    args = parser.parse_args()

    db_path = DB_PATH
    if args.db:
        db_path = Path(args.db)

    conn = open_db(db_path)

    if args.backfill_embeddings:
        done, failed = backfill_embeddings(conn)
        print(f"Backfill complete: {done} embedded, {failed} failed", file=sys.stderr)

    elif args.batch:
        count = ingest_batch(conn, args.human_id, args.channel, args.batch)
        print(f"Ingested {count} messages from {args.batch}", file=sys.stderr)

    elif args.from_stdin:
        text = sys.stdin.read()
        ingest_one(conn, args.human_id, args.channel, text)

    elif args.message:
        ingest_one(conn, args.human_id, args.channel, args.message)

    else:
        parser.print_help()
        sys.exit(1)

    conn.close()


if __name__ == "__main__":
    main()
