{
  "id": "mc-booking",
  "name": "Miniclaw Booking",
  "description": "Appointment scheduling with cloud DB, payment provider integration, and embeddable widget.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "vaultBin": { "type": "string" },
      "paymentProvider": { "type": "string" },
      "port": { "type": "number" },
      "origins": { "type": "array", "items": { "type": "string" } },
      "availableDays": { "type": "array", "items": { "type": "number" } },
      "timeSlots": { "type": "array", "items": { "type": "number" } },
      "durationMinutes": { "type": "number" },
      "priceCents": { "type": "number" },
      "maxPerDay": { "type": "number" },
      "windowWeeks": { "type": "number" }
    }
  }
}
