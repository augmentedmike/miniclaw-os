{
  "name": "@miniclaw/mc-docs",
  "version": "1.0.0",
  "description": "Document authoring and versioning plugin for MiniClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "cli": "node dist/cli/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
