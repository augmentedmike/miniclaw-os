{
  "id": "mc-queue",
  "name": "Queue Triage",
  "description": "Enforces queue-based execution for channel sessions: channel messages triage to board cards, cron workers execute. Prevents inline work in TG/Discord/Slack DMs and groups.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled":             { "type": "boolean" },
      "applyToChannels":     { "type": "boolean" },
      "applyToDMs":          { "type": "boolean" },
      "haikuModel":          { "type": "string" },
      "sonnetModel":         { "type": "string" },
      "opusModel":           { "type": "string" },
      "maxToolCallsPerTurn": { "type": "number" },
      "tgLogChatId":         { "type": "string" },
      "tgBotName":           { "type": "string" },
      "boardUrl":            { "type": "string" }
    }
  }
}
