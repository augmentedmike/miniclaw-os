#!/usr/bin/env bash
# mc-smoke — confirm MiniClaw systems and tools are present and functional
set -euo pipefail

PASS=0
FAIL=0
WARN=0

pass() { echo "  ✓  $1"; PASS=$(( PASS + 1 )); }
fail() { echo "  ✗  $1  →  $2"; FAIL=$(( FAIL + 1 )); }
warn() { echo "  ⚠  $1  →  $2"; WARN=$(( WARN + 1 )); }
section() { echo ""; echo "── $1"; }

STATE_DIR="${OPENCLAW_STATE_DIR:-${HOME}/.openclaw}"
MINICLAW_DIR="$STATE_DIR/miniclaw"
VAULT_ROOT="$MINICLAW_DIR/SYSTEM/vault"

# ── mc-vault ──────────────────────────────────────────────────────────────────
section "mc-vault"

if command -v mc-vault &>/dev/null; then
  pass "on PATH ($(command -v mc-vault))"
else
  fail "not found" "run installer: ./install.sh"
fi

if [[ -f "$VAULT_ROOT/key.txt" ]]; then
  pass "vault initialized (key.txt present)"
else
  fail "vault not initialized" "run: mc-vault init"
fi

TEST_VAL="smoke-test-$$"
if OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault set _smoke_test "$TEST_VAL" &>/dev/null 2>&1 && \
   OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault export _smoke_test 2>/dev/null | grep -q "$TEST_VAL"; then
  pass "encrypt/decrypt roundtrip ok"
  OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault rm _smoke_test &>/dev/null 2>&1 || true
else
  fail "encrypt/decrypt failed" "check age binaries and vault key"
  OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault rm _smoke_test &>/dev/null 2>&1 || true
fi

# ── age ───────────────────────────────────────────────────────────────────────
section "age"

for bin in /opt/homebrew/bin/age /opt/homebrew/bin/age-keygen; do
  if [[ -x "$bin" ]]; then
    pass "$bin"
  else
    fail "$bin" "brew install age"
  fi
done

# Verify the age key can actually encrypt/decrypt a payload directly
AGE_KEY="$VAULT_ROOT/key.txt"
if [[ -f "$AGE_KEY" ]]; then
  AGE_RECIPIENT=$(grep -oE 'age1[a-z0-9]+' "$AGE_KEY" | head -1 || true)
  if [[ -n "$AGE_RECIPIENT" ]]; then
    AGE_PROBE="smoke-$$-$(date +%s)"
    if echo "$AGE_PROBE" | age -r "$AGE_RECIPIENT" 2>/dev/null | age -d -i "$AGE_KEY" 2>/dev/null | grep -q "$AGE_PROBE"; then
      pass "age key roundtrip (encrypt → decrypt)"
    else
      fail "age key roundtrip failed" "key at $AGE_KEY may be corrupt"
    fi
  else
    fail "no age recipient in key file" "$AGE_KEY does not contain a valid public key"
  fi
fi

# ── qmd (optional — memory injection) ────────────────────────────────────────
section "qmd  [optional]"

if command -v qmd &>/dev/null; then
  pass "on PATH ($(command -v qmd))"

  for col in mc-memory workspace; do
    if qmd collection list 2>/dev/null | grep -q "^${col}"; then
      files=$(qmd collection list 2>/dev/null | grep -A3 "^${col}" | grep "Files:" | awk '{print $2}' || echo "0")
      pass "collection '$col' (${files:-0} files)"
    else
      warn "collection '$col' missing" "run: qmd collection add $col <path>"
    fi
  done

  if qmd search "identity" -n 1 &>/dev/null 2>&1; then
    pass "search functional"
  else
    warn "search returned no results" "run: qmd update && qmd embed"
  fi
else
  warn "qmd not found" "memory injection unavailable — run: npm install -g qmd"
fi

# ── soul-backups (optional) ───────────────────────────────────────────────────
section "soul-backups  [optional]"

SNAPSHOTS_DIR="${STATE_DIR}/soul-backups"
if [[ -d "$SNAPSHOTS_DIR" ]]; then
  count=$(ls "$SNAPSHOTS_DIR" 2>/dev/null | wc -l | tr -d ' ')
  pass "soul-backups present ($count snapshots)"
else
  warn "soul-backups dir missing" "run: mkdir -p $SNAPSHOTS_DIR"
fi

# ── required directories ──────────────────────────────────────────────────────
section "required directories"

for reqdir in "$STATE_DIR/USER/memory" "$STATE_DIR/USER/brain" "$STATE_DIR/soul-backups"; do
  if [[ -d "$reqdir" ]]; then
    pass "$(basename "$reqdir")/ exists"
  else
    fail "$(basename "$reqdir")/ missing" "run: mkdir -p $reqdir"
  fi
done

# ── inbox ─────────────────────────────────────────────────────────────────────
section "inbox"

INBOX_CMD="${HOME}/.claude-inbox/msg"
if [[ -x "$INBOX_CMD" ]]; then
  pass "CLI present and executable"
else
  fail "CLI missing or not executable" "$INBOX_CMD"
fi

if "$INBOX_CMD" check &>/dev/null 2>&1; then
  pass "check command functional"
else
  warn "check returned non-zero" "may be empty or key issue"
fi

# ── openclaw ──────────────────────────────────────────────────────────────────
section "openclaw"

if command -v openclaw &>/dev/null; then
  pass "on PATH — $(openclaw --version 2>/dev/null | head -1 || echo 'version unknown')"
else
  fail "not found" "npm install -g openclaw@latest"
fi

if [[ -f "$STATE_DIR/openclaw.json" ]]; then
  pass "openclaw.json present"
else
  fail "openclaw.json missing" "$STATE_DIR/openclaw.json"
fi

# ── runtime ───────────────────────────────────────────────────────────────────
section "runtime"

for tool in node; do
  if command -v "$tool" &>/dev/null; then
    ver=$("$tool" --version 2>/dev/null | head -1)
    pass "$tool ($ver)"
  else
    fail "$tool not found" "required — run installer"
  fi
done

# uv is optional
if command -v uv &>/dev/null; then
  pass "uv ($(uv --version 2>/dev/null | head -1))"
else
  warn "uv not found" "optional — brew install uv"
fi

# ── board DB ──────────────────────────────────────────────────────────────────
section "board DB"

BOARD_DB="$STATE_DIR/USER/brain/board.db"
if [[ -f "$BOARD_DB" ]]; then
  pass "board.db exists"
  if command -v python3 &>/dev/null; then
    db_check=$(python3 -c "
import sqlite3
db = sqlite3.connect('$BOARD_DB')
tables = [r[0] for r in db.execute(\"SELECT name FROM sqlite_master WHERE type='table'\").fetchall()]
cards = db.execute('SELECT COUNT(*) FROM cards').fetchone()[0] if 'cards' in tables else 0
projects = db.execute('SELECT COUNT(*) FROM projects').fetchone()[0] if 'projects' in tables else 0
mc_prj = db.execute(\"SELECT id FROM projects WHERE id='prj_miniclaw_enh'\").fetchone() if 'projects' in tables else None
print('tables:' + ','.join(tables))
print('cards:' + str(cards))
print('projects:' + str(projects))
print('miniclaw_project:' + ('yes' if mc_prj else 'no'))
db.close()
" 2>&1 || true)
    if echo "$db_check" | grep -q "^tables:"; then
      tables=$(echo "$db_check" | grep "^tables:" | cut -d: -f2)
      cards=$(echo "$db_check" | grep "^cards:" | cut -d: -f2)
      projects=$(echo "$db_check" | grep "^projects:" | cut -d: -f2)
      mc_prj=$(echo "$db_check" | grep "^miniclaw_project:" | cut -d: -f2)
      pass "board.db schema ($tables)"
      pass "board.db data ($cards cards, $projects projects)"
      if [[ "$mc_prj" == "yes" ]]; then
        pass "required project prj_miniclaw_enh present"
      else
        fail "required project prj_miniclaw_enh missing" "run install.sh or seed the board DB"
      fi
    else
      fail "board.db cannot be read" "$(echo "$db_check" | grep -v "^$" | head -1)"
    fi
  fi
else
  warn "board.db not found" "will be created on first mc board use"
fi

# ── backups ──────────────────────────────────────────────────────────────────
section "backups"

BACKUP_DIR="$STATE_DIR/backups"
if [[ -d "$BACKUP_DIR" ]]; then
  backup_count=$(ls "$BACKUP_DIR"/*.tgz 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$backup_count" -gt 0 ]]; then
    latest=$(ls -t "$BACKUP_DIR"/*.tgz 2>/dev/null | head -1)
    latest_name=$(basename "$latest")
    latest_age_days=$(( ( $(date +%s) - $(stat -f%m "$latest" 2>/dev/null || stat -c%Y "$latest" 2>/dev/null || echo 0) ) / 86400 ))
    pass "backups present ($backup_count archives, latest: $latest_name)"
    if [[ "$latest_age_days" -le 7 ]]; then
      pass "latest backup is recent (${latest_age_days}d old)"
    else
      warn "latest backup is ${latest_age_days}d old" "run: mc backup now"
    fi
    # Verify the latest archive is a valid tgz
    if tar tzf "$latest" &>/dev/null; then
      pass "latest backup is valid tgz"
    else
      fail "latest backup is corrupt" "$latest_name"
    fi
  else
    warn "backup dir exists but empty" "run: mc backup now"
  fi
else
  warn "no backup dir" "run: mc backup now"
fi

# ── plugin secrets ───────────────────────────────────────────────────────────
section "plugin secrets"

MANIFEST="$MINICLAW_DIR/MANIFEST.json"
if [[ -f "$MANIFEST" ]] && command -v node &>/dev/null; then
  secrets_check=$(node -e "
    const manifest = require('$MANIFEST');
    const plugins = manifest.plugins || [];
    for (const p of plugins) {
      if (!p.requires || p.requires.length === 0) continue;
      for (const key of p.requires) {
        console.log(p.id + ':' + key + ':' + (p.optional ? 'optional' : 'required'));
      }
    }
  " 2>&1 || true)

  if [[ -n "$secrets_check" ]]; then
    while IFS=: read -r plugin_id secret_key optionality; do
      # Check if the secret exists in vault
      if OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault export "$secret_key" &>/dev/null 2>&1; then
        pass "$plugin_id → $secret_key present"
      elif [[ "$optionality" == "optional" ]]; then
        warn "$plugin_id → $secret_key missing" "optional — mc-vault set $secret_key <value>"
      else
        fail "$plugin_id → $secret_key missing" "required — mc-vault set $secret_key <value>"
      fi
    done <<< "$secrets_check"
  else
    pass "no plugins require vault secrets"
  fi
else
  warn "MANIFEST.json not found or node unavailable" "cannot check plugin secrets"
fi

# ── plugin CLI (PATH + executable) ──────────────────────────────────────────
section "plugin CLI"

MINICLAW_PLUGINS_DIR="$MINICLAW_DIR/plugins"
SYSTEM_BIN="$MINICLAW_DIR/SYSTEM/bin"

if [[ ! -d "$MINICLAW_PLUGINS_DIR" ]]; then
  warn "plugins dir not found" "$MINICLAW_PLUGINS_DIR"
else
  # Collect plugins to test, then run --help checks in parallel
  declare -A CLI_BINS=()
  declare -a CLI_MISSING=()
  declare -a CLI_NO_PATH=()

  for plugin_dir in "$MINICLAW_PLUGINS_DIR"/mc-*/; do
    plugin_name="$(basename "$plugin_dir")"
    if command -v "$plugin_name" &>/dev/null; then
      CLI_BINS["$plugin_name"]="$(command -v "$plugin_name")"
    elif [[ -x "$SYSTEM_BIN/$plugin_name" ]]; then
      CLI_NO_PATH+=("$plugin_name")
    else
      CLI_MISSING+=("$plugin_name")
    fi
  done

  # Run --help for all found plugins in parallel
  TMPDIR_CLI=$(mktemp -d)
  for plugin_name in "${!CLI_BINS[@]}"; do
    cli_bin="${CLI_BINS[$plugin_name]}"
    (
      if [[ -x "$cli_bin" ]] && "$cli_bin" --help &>/dev/null 2>&1; then
        echo "PASS" > "$TMPDIR_CLI/$plugin_name"
      else
        echo "FAIL" > "$TMPDIR_CLI/$plugin_name"
      fi
    ) &
  done
  wait

  # Report results
  for plugin_name in "${!CLI_BINS[@]}"; do
    cli_bin="${CLI_BINS[$plugin_name]}"
    if [[ "$(cat "$TMPDIR_CLI/$plugin_name" 2>/dev/null)" == "PASS" ]]; then
      pass "$plugin_name callable ($cli_bin)"
    else
      fail "$plugin_name on PATH but not executable" "$cli_bin"
    fi
  done
  rm -rf "$TMPDIR_CLI"

  for plugin_name in "${CLI_NO_PATH[@]}"; do
    fail "$plugin_name exists in SYSTEM/bin but not on PATH" "add $SYSTEM_BIN to \$PATH"
  done
  for plugin_name in "${CLI_MISSING[@]}"; do
    fail "$plugin_name" "missing from SYSTEM/bin and PATH"
  done
fi

# ── gateway ──────────────────────────────────────────────────────────────────
section "gateway"

GW_PLIST="$HOME/Library/LaunchAgents/ai.openclaw.gateway.plist"
if [[ -f "$GW_PLIST" ]]; then
  pass "gateway LaunchAgent plist present"
else
  fail "gateway LaunchAgent plist missing" "run: openclaw gateway install --force"
fi

if launchctl list 2>/dev/null | grep -q "ai.openclaw.gateway"; then
  pass "gateway LaunchAgent loaded"
else
  fail "gateway LaunchAgent not loaded" "run: launchctl load $GW_PLIST"
fi

if command -v openclaw &>/dev/null; then
  GW_STATUS=$(openclaw gateway status 2>&1 || true)
  if echo "$GW_STATUS" | grep -qi "running\|listening\|connected\|uptime"; then
    pass "gateway process running"
  else
    fail "gateway not running" "run: openclaw gateway start"
  fi
fi

# ── telegram channel ──────────────────────────────────────────────────────────
section "telegram"

if command -v python3 &>/dev/null && [[ -f "$STATE_DIR/openclaw.json" ]]; then
  TG_CHECK=$(python3 - "$STATE_DIR/openclaw.json" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f: cfg = json.load(f)
ch = cfg.get("channels", {}).get("telegram", {})
if not ch:
    print("MISSING")
elif not ch.get("enabled"):
    print("DISABLED")
elif not ch.get("botToken"):
    print("NO_TOKEN")
else:
    print("OK")
PYEOF
  )
  case "$TG_CHECK" in
    OK)       pass "telegram channel configured and enabled" ;;
    MISSING)  fail "telegram channel not in openclaw.json" "run setup wizard or add channels.telegram to config" ;;
    DISABLED) fail "telegram channel disabled" "set channels.telegram.enabled = true in openclaw.json" ;;
    NO_TOKEN) fail "telegram bot token missing" "set channels.telegram.botToken in openclaw.json" ;;
    *)        fail "telegram config check failed" "$TG_CHECK" ;;
  esac
else
  warn "cannot check telegram config" "python3 or openclaw.json missing"
fi

# ── LaunchAgents ─────────────────────────────────────────────────────────────
section "LaunchAgents"

for label in com.miniclaw.board-web ai.openclaw.gateway; do
  plist_path="$HOME/Library/LaunchAgents/$label.plist"
  if [[ ! -f "$plist_path" ]]; then
    fail "$label plist missing" "$plist_path"
    continue
  fi
  pass "$label plist present"
  if launchctl list 2>/dev/null | grep -q "$label"; then
    pass "$label loaded"
  else
    fail "$label not loaded" "run: launchctl load $plist_path"
  fi
done

# ── cron jobs ────────────────────────────────────────────────────────────────
section "cron jobs"

CRON_FILE="$STATE_DIR/cron/jobs.json"
MANIFEST_FILE="$MINICLAW_DIR/MANIFEST.json"

if [[ ! -f "$CRON_FILE" ]]; then
  fail "jobs.json missing" "$CRON_FILE — run install.sh"
else
  pass "jobs.json present"
  if [[ -f "$MANIFEST_FILE" ]] && command -v python3 &>/dev/null; then
    CRON_CHECK=$(python3 - "$CRON_FILE" "$MANIFEST_FILE" <<'PYEOF'
import json, sys
jobs_path, manifest_path = sys.argv[1], sys.argv[2]
with open(jobs_path) as f: jobs = json.load(f)
with open(manifest_path) as f: manifest = json.load(f)
job_names = {j["name"] for j in jobs.get("jobs", [])}
expected = [c["name"] for c in manifest.get("crons", [])]
missing = [n for n in expected if n not in job_names]
extra = [n for n in job_names if n not in expected and n not in ("_smoke_test",)]
if missing:
    for m in missing:
        print(f"MISSING:{m}")
if extra:
    for e in extra:
        print(f"EXTRA:{e}")
if not missing:
    print(f"OK:{len(expected)}")
PYEOF
    )
    while IFS= read -r line; do
      case "$line" in
        MISSING:*) fail "cron job missing: ${line#MISSING:}" "run install.sh to sync from MANIFEST.json" ;;
        EXTRA:*)   warn "unexpected cron job: ${line#EXTRA:}" "not in MANIFEST.json" ;;
        OK:*)      pass "all ${line#OK:} expected cron jobs present" ;;
      esac
    done <<< "$CRON_CHECK"
  fi
fi

# ── install verification ──────────────────────────────────────────────────────
section "install verification"

# Workspace files must not contain template placeholders
WORKSPACE_DIR="$STATE_DIR/workspace"
if [[ -d "$WORKSPACE_DIR" ]]; then
  PLACEHOLDER_COUNT=$(grep -rl '{{AGENT_NAME}}\|{{PRONOUNS}}\|{{AGENT_SHORT}}\|{{HUMAN_NAME}}\|{{VERSION}}\|{{DATE}}' "$WORKSPACE_DIR" 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$PLACEHOLDER_COUNT" -eq 0 ]]; then
    pass "workspace files personalized (no placeholders)"
  else
    fail "workspace has $PLACEHOLDER_COUNT file(s) with unresolved {{placeholders}}" "run install.sh or complete setup wizard"
  fi
else
  warn "workspace dir missing" "$WORKSPACE_DIR"
fi

# SOUL.md must contain the agent name from setup-state
SETUP_STATE="$STATE_DIR/USER/setup-state.json"
if [[ -f "$SETUP_STATE" && -f "$WORKSPACE_DIR/SOUL.md" ]]; then
  AGENT_NAME=$(python3 -c "import json; print(json.load(open('$SETUP_STATE')).get('assistantName',''))" 2>/dev/null || echo "")
  if [[ -n "$AGENT_NAME" ]]; then
    if grep -q "$AGENT_NAME" "$WORKSPACE_DIR/SOUL.md" 2>/dev/null; then
      pass "SOUL.md contains agent name ($AGENT_NAME)"
    else
      fail "SOUL.md missing agent name" "expected '$AGENT_NAME' in SOUL.md"
    fi
    if grep -q "$AGENT_NAME" "$WORKSPACE_DIR/IDENTITY.md" 2>/dev/null; then
      pass "IDENTITY.md contains agent name ($AGENT_NAME)"
    else
      fail "IDENTITY.md missing agent name" "expected '$AGENT_NAME' in IDENTITY.md"
    fi
  fi
fi

# openclaw.json must have gateway.mode
if [[ -f "$STATE_DIR/openclaw.json" ]]; then
  GW_MODE=$(python3 -c "import json; print(json.load(open('$STATE_DIR/openclaw.json')).get('gateway',{}).get('mode',''))" 2>/dev/null || echo "")
  if [[ "$GW_MODE" == "local" ]]; then
    pass "gateway.mode = local"
  else
    fail "gateway.mode not set to local" "current: '$GW_MODE'"
  fi

  # Model should use provider prefix
  MODEL=$(python3 -c "import json; print(json.load(open('$STATE_DIR/openclaw.json')).get('agents',{}).get('defaults',{}).get('model',{}).get('primary',''))" 2>/dev/null || echo "")
  if [[ "$MODEL" == *"/"* ]]; then
    pass "model uses provider prefix ($MODEL)"
  elif [[ -n "$MODEL" ]]; then
    fail "model missing provider prefix" "$MODEL — should be anthropic/$MODEL"
  fi
fi

# Check for duplicate cron jobs
if [[ -f "$STATE_DIR/cron/jobs.json" ]]; then
  DUP_CHECK=$(python3 -c "
import json, collections
with open('$STATE_DIR/cron/jobs.json') as f:
    jobs = json.load(f).get('jobs', [])
names = [j['name'] for j in jobs]
dupes = [n for n, c in collections.Counter(names).items() if c > 1]
if dupes:
    print('DUPES:' + ','.join(dupes))
else:
    print('OK:' + str(len(names)))
" 2>/dev/null || echo "ERROR")
  case "$DUP_CHECK" in
    DUPES:*) fail "duplicate cron jobs: ${DUP_CHECK#DUPES:}" "remove duplicates with: openclaw cron rm <id>" ;;
    OK:*)    pass "no duplicate cron jobs (${DUP_CHECK#OK:} total)" ;;
    *)       warn "could not check cron jobs" "parse error" ;;
  esac
fi

# gh CLI available
if command -v gh &>/dev/null; then
  pass "gh CLI on PATH ($(gh --version 2>/dev/null | head -1))"
else
  fail "gh CLI not on PATH" "run: brew install gh"
fi

# Claude Code available
if command -v claude &>/dev/null; then
  pass "claude code on PATH ($(claude --version 2>/dev/null | head -1))"
else
  fail "claude code not on PATH" "run: npm install -g @anthropic-ai/claude-code"
fi

# ── browser ──────────────────────────────────────────────────────────────────
section "browser"

if [[ -d "/Applications/Google Chrome.app" ]]; then
  pass "Google Chrome installed"
else
  fail "Google Chrome not installed" "brew install --cask google-chrome"
fi

MC_CHROME="$MINICLAW_DIR/SYSTEM/bin/mc-chrome"
if [[ -x "$MC_CHROME" ]]; then
  pass "mc-chrome launcher present ($MC_CHROME)"
else
  fail "mc-chrome launcher missing" "expected at $MC_CHROME"
fi

# ── power management (macOS) ──────────────────────────────────────────────────
if [[ "$(uname)" == "Darwin" ]]; then
  section "power management"

  DISK_SLEEP=$(pmset -g 2>/dev/null | grep disksleep | awk '{print $2}')
  AUTO_RESTART=$(pmset -g 2>/dev/null | grep autorestart | awk '{print $2}')

  if [[ "$DISK_SLEEP" == "0" ]]; then
    pass "disksleep = 0 (disk sleep disabled)"
  else
    fail "disksleep = ${DISK_SLEEP:-unknown}" "run: sudo pmset -a disksleep 0"
  fi

  if [[ "$AUTO_RESTART" == "1" ]]; then
    pass "autorestart = 1 (auto restart after power failure)"
  else
    fail "autorestart = ${AUTO_RESTART:-unknown}" "run: sudo pmset -a autorestart 1"
  fi
fi

# ── mc-memo roundtrip ─────────────────────────────────────────────────────
section "mc-memo roundtrip"

if command -v openclaw &>/dev/null; then
  SMOKE_CARD="_smoke_test_memo_$$"
  SMOKE_NOTE="smoke-roundtrip-$(date +%s)"

  # Write
  if openclaw mc-memo set "$SMOKE_CARD" "$SMOKE_NOTE" &>/dev/null 2>&1; then
    pass "mc-memo set (wrote test note)"
  else
    fail "mc-memo set failed" "openclaw mc-memo set returned non-zero"
  fi

  # Read back and verify content
  MEMO_CONTENT=$(openclaw mc-memo get "$SMOKE_CARD" 2>/dev/null || true)
  if echo "$MEMO_CONTENT" | grep -q "$SMOKE_NOTE"; then
    pass "mc-memo get (roundtrip verified — content matches)"
  else
    fail "mc-memo get failed" "expected '$SMOKE_NOTE' in output, got: $(echo "$MEMO_CONTENT" | head -1)"
  fi

  # Clear
  if openclaw mc-memo clear "$SMOKE_CARD" &>/dev/null 2>&1; then
    pass "mc-memo clear (cleanup ok)"
  else
    fail "mc-memo clear failed" "openclaw mc-memo clear returned non-zero"
  fi
else
  fail "openclaw not found" "cannot test mc-memo"
fi

# ── mc-memory roundtrip ──────────────────────────────────────────────────
section "mc-memory roundtrip"

if command -v openclaw &>/dev/null; then
  SMOKE_MEM_CARD="_smoke_test_memory_$$"
  SMOKE_MEM_NOTE="Smoke test roundtrip: this is a memory write verification with enough content to pass the quality gate and confirm data persistence through the memo pipeline."

  # Write via mc-memory (should route to memo because of card context)
  if openclaw mc-memory write "$SMOKE_MEM_NOTE" --card "$SMOKE_MEM_CARD" &>/dev/null 2>&1; then
    pass "mc-memory write (routed to memo)"
  else
    # mc-memory write may not support --card flag via CLI; try without
    warn "mc-memory write with --card failed" "CLI may not support --card flag"
  fi

  # Verify the memo landed via mc-memo get
  MEMO_CHECK=$(openclaw mc-memo get "$SMOKE_MEM_CARD" 2>/dev/null || true)
  if echo "$MEMO_CHECK" | grep -q "roundtrip"; then
    pass "mc-memory → mc-memo verified (content arrived in memo store)"
  else
    warn "mc-memory → mc-memo not verified" "memo file may not contain expected content"
  fi

  # Cleanup
  openclaw mc-memo clear "$SMOKE_MEM_CARD" &>/dev/null 2>&1 || true
else
  fail "openclaw not found" "cannot test mc-memory"
fi

# ── summary ───────────────────────────────────────────────────────────────────
echo ""
echo "────────────────────────────────────────"
echo "  ${PASS} passed  ${WARN} warned  ${FAIL} failed"
echo "────────────────────────────────────────"

[[ $FAIL -eq 0 ]]
