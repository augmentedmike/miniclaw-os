#!/usr/bin/env bash
# mc-doctor — diagnose and fix miniclaw issues
#
# Runs the same checks as mc-smoke, but attempts to repair failures.
# Safe to re-run — skips anything already healthy.
#
# Usage:
#   mc-doctor          Interactive — asks before each fix
#   mc-doctor --auto   Auto-fix everything without prompting

set -euo pipefail

AUTO=false
[[ "${1:-}" == "--auto" ]] && AUTO=true

FIXED=0
SKIPPED=0
FAILED=0

OPENCLAW_DIR="${HOME}/.openclaw"
MINICLAW_DIR="$OPENCLAW_DIR/miniclaw"
VAULT_ROOT="$MINICLAW_DIR/SYSTEM/vault"
LOCAL_BIN="$HOME/.local/bin"

# ── Colours ───────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

ok()      { echo -e "  ${GREEN}[✓]${NC} $1"; }
fixed()   { echo -e "  ${GREEN}[+]${NC} $1"; FIXED=$(( FIXED + 1 )); }
skip()    { echo -e "  ${YELLOW}[-]${NC} $1"; SKIPPED=$(( SKIPPED + 1 )); }
broke()   { echo -e "  ${RED}[✗]${NC} $1"; FAILED=$(( FAILED + 1 )); }
section() { echo -e "\n${BOLD}── $1${NC}"; }

# Ask user before fixing (unless --auto)
# Returns 0 = proceed, 1 = skip
ask() {
  local msg="$1"
  if $AUTO; then
    echo -e "  ${BLUE}[→]${NC} $msg"
    return 0
  fi
  printf "  ${YELLOW}fix?${NC} %s [Y/n] " "$msg"
  read -r ans
  [[ -z "$ans" || "$ans" == "y" || "$ans" == "Y" ]]
}

echo ""
echo -e "${BOLD}mc-doctor${NC}"
$AUTO && echo "  mode: auto-fix" || echo "  mode: interactive"

# ── Homebrew ──────────────────────────────────────────────────────────────────
section "Homebrew"

if command -v brew &>/dev/null; then
  ok "Homebrew present"
else
  if ask "Install Homebrew?"; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" \
      && fixed "Homebrew installed" || broke "Homebrew install failed"
  else
    skip "Homebrew"
  fi
fi

# ── age ───────────────────────────────────────────────────────────────────────
section "age"

if command -v age &>/dev/null; then
  ok "age present"
else
  if ask "Install age (brew install age)?"; then
    brew install age && fixed "age installed" || broke "age install failed"
  else
    skip "age"
  fi
fi

# ── qmd ───────────────────────────────────────────────────────────────────────
section "qmd  [optional]"

if command -v qmd &>/dev/null; then
  ok "qmd present"
else
  if ask "Install qmd (npm install -g qmd)?"; then
    npm install -g qmd && fixed "qmd installed" || broke "qmd install failed"
  else
    skip "qmd"
  fi
fi

if command -v qmd &>/dev/null; then
  for col in mc-memory workspace; do
    if ! qmd collection list 2>/dev/null | grep -q "^${col}"; then
      default_path="$OPENCLAW_DIR/USER/memory"
      [[ "$col" == "workspace" ]] && default_path="$OPENCLAW_DIR/workspace"
      if ask "Register qmd collection '$col' → $default_path?"; then
        mkdir -p "$default_path"
        qmd collection add "$col" "$default_path" \
          && fixed "collection '$col' registered" || broke "failed to register '$col'"
      else
        skip "qmd collection '$col'"
      fi
    else
      ok "qmd collection '$col' present"
    fi
  done
fi

# ── openclaw ──────────────────────────────────────────────────────────────────
section "openclaw"

if ! command -v openclaw &>/dev/null; then
  if ask "Install openclaw (npm install -g openclaw@latest)?"; then
    npm install -g openclaw@latest && fixed "openclaw installed" || broke "openclaw install failed"
  else
    skip "openclaw"
  fi
else
  ok "openclaw present ($(openclaw --version 2>/dev/null | head -1))"
fi

if [[ ! -f "$OPENCLAW_DIR/openclaw.json" ]]; then
  if ask "Create minimal openclaw.json?"; then
    mkdir -p "$OPENCLAW_DIR"
    python3 - "$OPENCLAW_DIR/openclaw.json" <<'PYEOF'
import json, sys
cfg = {
  "meta": {},
  "agents": { "defaults": { "model": { "primary": "claude-sonnet-4-6" }, "compaction": { "mode": "safeguard" } } },
  "plugins": {}
}
with open(sys.argv[1], "w") as f:
    json.dump(cfg, f, indent=2); f.write("\n")
PYEOF
    fixed "openclaw.json created"
  else
    skip "openclaw.json"
  fi
else
  ok "openclaw.json present"
fi

# ── vault ─────────────────────────────────────────────────────────────────────
section "vault"

MC_VAULT="$LOCAL_BIN/mc-vault"

if ! command -v mc-vault &>/dev/null; then
  broke "mc-vault not found — run install.sh first"
elif [[ ! -f "$VAULT_ROOT/key.txt" ]]; then
  if ask "Initialise vault (mc-vault init)?"; then
    OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault init \
      && fixed "vault initialised" || broke "vault init failed"
  else
    skip "vault init"
  fi
else
  # Verify encrypt/decrypt works
  TEST_VAL="doctor-test-$$"
  if OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault set _doctor_test "$TEST_VAL" &>/dev/null 2>&1 && \
     OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault export _doctor_test 2>/dev/null | grep -q "$TEST_VAL"; then
    OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault rm _doctor_test &>/dev/null 2>&1 || true
    ok "vault encrypt/decrypt ok"
  else
    OPENCLAW_VAULT_ROOT="$VAULT_ROOT" mc-vault rm _doctor_test &>/dev/null 2>&1 || true
    broke "vault encrypt/decrypt failed — age binaries ok but vault may be corrupt"
  fi
fi

# ── directories ───────────────────────────────────────────────────────────────
section "directories"

for dir in \
  "$OPENCLAW_DIR/soul-backups" \
  "$OPENCLAW_DIR/projects" \
  "$OPENCLAW_DIR/USER/memory"; do
  if [[ ! -d "$dir" ]]; then
    if ask "Create $dir?"; then
      mkdir -p "$dir" && fixed "created $dir" || broke "failed to create $dir"
    else
      skip "$dir"
    fi
  else
    ok "$dir"
  fi
done

# ── plugin deps ───────────────────────────────────────────────────────────────
section "plugin dependencies"

PLUGINS_DIR="$MINICLAW_DIR/plugins"

if [[ ! -d "$PLUGINS_DIR" ]]; then
  broke "plugins dir not found — run install.sh first"
elif ! command -v npm &>/dev/null; then
  skip "npm not found — cannot install plugin deps"
else
  for plugin_dir in "$PLUGINS_DIR"/*/; do
    plugin_name="$(basename "$plugin_dir")"
    if [[ -f "$plugin_dir/package.json" && ! -d "$plugin_dir/node_modules" ]]; then
      if ask "Install deps for $plugin_name (npm install)?"; then
        (cd "$plugin_dir" && npm install 2>/dev/null) \
          && fixed "$plugin_name deps installed" || broke "$plugin_name npm install failed"
      else
        skip "$plugin_name deps"
      fi
    else
      ok "$plugin_name deps present"
    fi
  done
fi

# ── gateway ──────────────────────────────────────────────────────────────────
section "gateway"

GW_PLIST="$HOME/Library/LaunchAgents/ai.openclaw.gateway.plist"

if command -v openclaw &>/dev/null; then
  GW_STATUS=$(openclaw gateway status 2>&1 || true)
  if echo "$GW_STATUS" | grep -qi "running\|listening\|connected\|uptime"; then
    ok "gateway running"
  elif [[ ! -f "$GW_PLIST" ]]; then
    if ask "Install gateway LaunchAgent (openclaw gateway install --force)?"; then
      openclaw gateway install --force 2>/dev/null \
        && fixed "gateway LaunchAgent installed" || broke "gateway install failed"
    else
      skip "gateway install"
    fi
  else
    if ask "Start gateway (openclaw gateway start)?"; then
      openclaw gateway start 2>/dev/null \
        && fixed "gateway started" || broke "gateway start failed — try: openclaw gateway install --force"
    else
      skip "gateway start"
    fi
  fi
else
  broke "openclaw not found — cannot manage gateway"
fi

# ── LaunchAgents ─────────────────────────────────────────────────────────────
section "LaunchAgents"

for label in com.miniclaw.board-web ai.openclaw.gateway; do
  plist_path="$HOME/Library/LaunchAgents/$label.plist"
  if [[ ! -f "$plist_path" ]]; then
    if [[ "$label" == "ai.openclaw.gateway" ]]; then
      # gateway plist is managed by openclaw gateway install
      continue
    fi
    broke "$label plist missing — run install.sh"
    continue
  fi
  if ! launchctl list 2>/dev/null | grep -q "$label"; then
    if ask "Load LaunchAgent $label?"; then
      launchctl load "$plist_path" 2>/dev/null \
        && fixed "$label loaded" || broke "failed to load $label"
    else
      skip "$label"
    fi
  else
    ok "$label loaded"
  fi
done

# ── cron jobs ────────────────────────────────────────────────────────────────
section "cron jobs"

CRON_FILE="$OPENCLAW_DIR/cron/jobs.json"
MANIFEST_FILE="$MINICLAW_DIR/MANIFEST.json"

if [[ ! -f "$CRON_FILE" ]]; then
  if ask "Create jobs.json with crons from MANIFEST?"; then
    mkdir -p "$(dirname "$CRON_FILE")"
    python3 - "$CRON_FILE" "$MANIFEST_FILE" <<'PYEOF'
import json, uuid, os, sys
cron_file, manifest_path = sys.argv[1], sys.argv[2]
store = {"version": 1, "jobs": []}
try:
    with open(manifest_path) as f:
        manifest = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    manifest = {}
for mc in manifest.get("crons", []):
    store["jobs"].append({
        "id": str(uuid.uuid4()),
        "name": mc["name"],
        "schedule": mc["schedule"],
        "sessionTarget": mc.get("sessionTarget", "isolated"),
        "model": mc.get("model", "claude-haiku-4-5-20251001"),
        "payload": {"kind": "agentTurn", "timeoutSeconds": mc.get("timeoutSeconds", 600), "messageFile": f"prompts/{mc['name']}.md"},
        "delivery": {"mode": "none"},
        "enabled": True
    })
with open(cron_file, "w") as f:
    json.dump(store, f, indent=2)
print(f"  Created with {len(store['jobs'])} job(s)")
PYEOF
    fixed "jobs.json created"
  else
    skip "jobs.json"
  fi
elif [[ -f "$MANIFEST_FILE" ]] && command -v python3 &>/dev/null; then
  MISSING_CRONS=$(python3 - "$CRON_FILE" "$MANIFEST_FILE" <<'PYEOF'
import json, sys
jobs_path, manifest_path = sys.argv[1], sys.argv[2]
with open(jobs_path) as f: jobs = json.load(f)
with open(manifest_path) as f: manifest = json.load(f)
job_names = {j["name"] for j in jobs.get("jobs", [])}
missing = [c["name"] for c in manifest.get("crons", []) if c["name"] not in job_names]
print(",".join(missing) if missing else "")
PYEOF
  )
  if [[ -n "$MISSING_CRONS" ]]; then
    if ask "Add missing cron jobs ($MISSING_CRONS) to jobs.json?"; then
      python3 - "$CRON_FILE" "$MANIFEST_FILE" <<'PYEOF'
import json, uuid, sys
cron_file, manifest_path = sys.argv[1], sys.argv[2]
with open(cron_file) as f: store = json.load(f)
with open(manifest_path) as f: manifest = json.load(f)
existing = {j["name"] for j in store.get("jobs", [])}
added = 0
for mc in manifest.get("crons", []):
    if mc["name"] not in existing:
        store.setdefault("jobs", []).append({
            "id": str(uuid.uuid4()),
            "name": mc["name"],
            "schedule": mc["schedule"],
            "sessionTarget": mc.get("sessionTarget", "isolated"),
            "model": mc.get("model", "claude-haiku-4-5-20251001"),
            "payload": {"kind": "agentTurn", "timeoutSeconds": mc.get("timeoutSeconds", 600), "messageFile": f"prompts/{mc['name']}.md"},
            "delivery": {"mode": "none"},
            "enabled": True
        })
        added += 1
with open(cron_file, "w") as f:
    json.dump(store, f, indent=2)
print(f"  Added {added} missing cron job(s)")
PYEOF
      fixed "missing cron jobs added"
    else
      skip "missing cron jobs"
    fi
  else
    ok "all MANIFEST crons present in jobs.json"
  fi
fi

# ── self-healing: create fix cards for remaining failures ────────────────
if [[ $FAILED -gt 0 ]] && command -v openclaw &>/dev/null; then
  section "self-healing"

  SMOKE_OUTPUT=$(mc-smoke 2>&1 || true)
  HEAL_CREATED=0

  while IFS= read -r fail_line; do
    [[ -z "$fail_line" ]] && continue
    label=$(echo "$fail_line" | sed 's/.*✗[[:space:]]*//' | sed 's/[[:space:]]*→.*//' | xargs)
    fix_hint=$(echo "$fail_line" | sed -n 's/.*→[[:space:]]*//p' | xargs)
    [[ -z "$label" ]] && continue

    component="system"
    plan="Investigate: $label. Suggested fix: ${fix_hint:-none provided}."

    # Map failure to known component + remediation
    combined="${label,,} ${fix_hint,,}"
    case "$combined" in
      *vault*init*)     component="mc-vault"; plan="Run: mc-vault init — creates age key and vault directory." ;;
      *encrypt*decrypt*) component="mc-vault"; plan="Check age binaries (brew install age) and vault key at SYSTEM/vault/key.txt." ;;
      *age*key*roundtrip*) component="age"; plan="Vault key may be corrupt. Regenerate: age-keygen -o ~/.openclaw/miniclaw/SYSTEM/vault/key.txt" ;;
      *age*recipient*)  component="age"; plan="Key file missing public key. Regenerate: age-keygen." ;;
      */opt/homebrew/bin/age*) component="age"; plan="Install age: brew install age." ;;
      *inbox*cli*)      component="inbox"; plan="Re-run installer to create ~/.claude-inbox/msg." ;;
      *openclaw.json*)  component="openclaw config"; plan="Re-run setup wizard or create openclaw.json." ;;
      *prj_miniclaw*)   component="board DB"; plan="Seed required project: re-run setup wizard complete step." ;;
      *board.db*cannot*) component="board DB"; plan="Board DB corrupt. Delete and re-seed via setup wizard." ;;
      *board.db*not*found*) component="board DB"; plan="Re-run setup wizard completion step." ;;
      *backup*corrupt*) component="backups"; plan="Delete corrupt archive and run: openclaw mc-backup now." ;;
      *secret*missing*) component="plugin secrets"; plan="Set missing vault secret: mc-vault set <key> <value>." ;;
      *not*on*path*)    component="plugin CLI"; plan="Add SYSTEM/bin to PATH in shell profile." ;;
      *not*executable*) component="plugin CLI"; plan="Fix permissions: chmod +x on the binary." ;;
      *missing*from*system*) component="plugin CLI"; plan="Re-run install.sh to generate CLI wrappers." ;;
      *gateway*plist*missing*) component="gateway"; plan="Run: openclaw gateway install --force." ;;
      *gateway*not*loaded*) component="gateway"; plan="Run: launchctl load ~/Library/LaunchAgents/ai.openclaw.gateway.plist" ;;
      *gateway*not*running*) component="gateway"; plan="Run: openclaw gateway start." ;;
      *telegram*not*in*) component="telegram"; plan="Re-run setup wizard or add channels.telegram to openclaw.json." ;;
      *telegram*disabled*) component="telegram"; plan="Set channels.telegram.enabled = true in openclaw.json." ;;
      *telegram*token*) component="telegram"; plan="Add channels.telegram.botToken in openclaw.json." ;;
      *plist*missing*)  component="LaunchAgents"; plan="Re-install plist via install.sh." ;;
      *not*loaded*)     component="LaunchAgents"; plan="Run: launchctl load ~/Library/LaunchAgents/<label>.plist" ;;
      *jobs.json*missing*) component="cron jobs"; plan="Re-run install.sh to sync cron/jobs.json from MANIFEST." ;;
      *cron*job*missing*) component="cron jobs"; plan="Re-run install.sh or add missing job to jobs.json." ;;
      *duplicate*cron*) component="cron jobs"; plan="Run: openclaw cron list, then openclaw cron rm <duplicate-id>." ;;
      *placeholder*)    component="workspace"; plan="Re-run install.sh to personalize workspace files." ;;
      *soul.md*missing*) component="workspace"; plan="Re-run workspace personalization via setup wizard." ;;
      *identity.md*missing*) component="workspace"; plan="Re-run workspace personalization via setup wizard." ;;
      *gateway.mode*)   component="openclaw config"; plan="Set gateway.mode = local in openclaw.json." ;;
      *provider*prefix*) component="openclaw config"; plan="Update model to use provider prefix (e.g. anthropic/claude-sonnet-4-5-20250514)." ;;
      *chrome*not*installed*) component="browser"; plan="Run: brew install --cask google-chrome." ;;
      *mc-chrome*missing*) component="browser"; plan="Re-run install.sh to create mc-chrome launcher." ;;
      *gh*cli*not*) component="GitHub CLI"; plan="Run: brew install gh && gh auth login." ;;
      *claude*code*not*) component="Claude Code"; plan="Run: npm install -g @anthropic-ai/claude-code." ;;
      *disksleep*)      component="power"; plan="Run: sudo pmset -a disksleep 0." ;;
      *autorestart*)    component="power"; plan="Run: sudo pmset -a autorestart 1." ;;
    esac

    title="Fix: $component — $label"

    # Skip if a card already exists for this failure
    has_dup=$(openclaw mc-board board --json 2>/dev/null | python3 -c "
import json, sys
try:
    cards = json.load(sys.stdin)
    if not isinstance(cards, list): cards = cards.get('cards', [])
    t = '''$title'''.lower()
    for c in cards:
        tags = c.get('tags', [])
        if 'smoke-fix' in tags and c.get('col') not in ('done','archived','shipped'):
            if c.get('title','').lower() == t:
                print('DUP'); break
except: pass
" 2>/dev/null || true)

    if [[ "$has_dup" == "DUP" ]]; then
      ok "card exists: $component — $label"
      continue
    fi

    if $AUTO || ask "Create fix card for: $component — $label?"; then
      openclaw mc-board create \
        --title "$title" \
        --priority high \
        --tags "setup,smoke-fix,self-healing" \
        --problem "Smoke test failure:\n\n**Check:** $label\n**Suggested fix:** $fix_hint\n\nAuto-detected by mc-doctor." \
        --plan "1. $plan\n2. Verify: mc-smoke\n3. If user action needed, add hold tag." \
        --criteria "- [ ] \"$label\" passes\n- [ ] No regressions" \
        --notes "Auto-created by mc-doctor on $(date -Iseconds)" \
        &>/dev/null && { fixed "created card: $title"; HEAL_CREATED=$(( HEAL_CREATED + 1 )); } \
        || broke "failed to create card for: $label"
    else
      skip "card for: $label"
    fi

  done <<< "$(echo "$SMOKE_OUTPUT" | grep '✗')"

  if [[ $HEAL_CREATED -gt 0 ]]; then
    echo -e "\n  ${GREEN}Created $HEAL_CREATED fix card(s) — board worker will pick them up.${NC}"

    # Notify via Telegram if configured
    if command -v python3 &>/dev/null && [[ -f "$OPENCLAW_DIR/USER/setup-state.json" ]]; then
      python3 - "$OPENCLAW_DIR/USER/setup-state.json" "$HEAL_CREATED" <<'TGEOF' 2>/dev/null || true
import json, sys, urllib.request
with open(sys.argv[1]) as f: state = json.load(f)
token, chat = state.get("telegramBotToken", ""), state.get("telegramChatId", "")
if not token or not chat: sys.exit(0)
msg = f"🔧 mc-doctor created {sys.argv[2]} fix card(s) on the board backlog."
data = json.dumps({"chat_id": chat, "text": msg}).encode()
req = urllib.request.Request(f"https://api.telegram.org/bot{token}/sendMessage",
    data=data, headers={"Content-Type": "application/json"})
urllib.request.urlopen(req, timeout=10)
TGEOF
    fi
  fi
fi

# ── agent-assisted repair ────────────────────────────────────────────────────
# For failures cards can't solve, dispatch to the agent loop.
if [[ $FAILED -gt 0 ]] && command -v openclaw &>/dev/null; then
  GW_STATUS=$(openclaw gateway status 2>&1 || true)
  if echo "$GW_STATUS" | grep -qi "running\|listening\|connected\|uptime"; then
    if ask "Dispatch remaining failure(s) to the openclaw agent for repair?"; then
      FAILURES=$(echo "$SMOKE_OUTPUT" | grep '✗' | sed 's/^  ✗  /- /' || true)
      openclaw agent --local --message "mc-doctor found failures:
$FAILURES
Please diagnose and fix each. Run mc-smoke to verify." --timeout 300 2>&1 \
        && fixed "agent repair completed" \
        || broke "agent repair failed or timed out"
    else
      skip "agent-assisted repair"
    fi
  fi
fi

# ── summary ───────────────────────────────────────────────────────────────────
echo ""
echo "────────────────────────────────────────"
echo "  ${FIXED} fixed  ${SKIPPED} skipped  ${FAILED} failed"
echo "────────────────────────────────────────"

if [[ $FAILED -gt 0 ]]; then
  echo ""
  echo "  Run mc-smoke to verify remaining issues."
  echo ""
  exit 1
fi

if [[ $FIXED -gt 0 ]]; then
  echo ""
  echo "  Run mc-smoke to confirm everything is healthy."
  echo ""
fi
