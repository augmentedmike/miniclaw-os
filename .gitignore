# End-user data — created and owned by the end user, never committed
user/

# Vault — NEVER commit secrets, keys, or encrypted blobs
system/vault/

# Node dependencies
node_modules/
**/node_modules/

# Build output
dist/
*.js.map

# Age-encrypted secrets (committed separately if needed, never plaintext)
*.age

# Environment and credential files
.env
.env.*
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets/
.secret

# Logs
*.log

# OS noise
.DS_Store
Thumbs.db
