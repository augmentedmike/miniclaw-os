{
  "id": "mc-reflection",
  "name": "Miniclaw Reflection",
  "description": "Nightly self-reflection — reviews the day's memories, board state, KB entries, and session transcripts to extract lessons, create action items, and build long-term knowledge.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "reflectionDir": {
        "type": "string",
        "description": "Directory for reflection snapshots (default: ~/.openclaw/miniclaw/USER/reflections)"
      },
      "memoryDir": {
        "type": "string",
        "description": "Episodic memory directory (default: ~/.openclaw/workspace/memory)"
      },
      "boardDbPath": {
        "type": "string",
        "description": "Path to board.db (default: ~/.openclaw/miniclaw/USER/brain)"
      },
      "kbDbPath": {
        "type": "string",
        "description": "Path to kb directory (default: ~/.openclaw/miniclaw/USER/kb)"
      },
      "transcriptsDir": {
        "type": "string",
        "description": "Claude session transcripts directory (default: ~/.claude/projects)"
      }
    }
  }
}
