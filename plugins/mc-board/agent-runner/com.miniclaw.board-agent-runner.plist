  <key>StandardOutPath</key>
  <string>/Users/augmentedmike/am/logs/agent-runner.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/augmentedmike/am/logs/agent-runner.stderr.log</string>

  <key>WorkingDirectory</key>
  <string>/Users/augmentedmike/am/miniclaw/plugins/mc-board/agent-runner</string>
</dict>
</plist>
