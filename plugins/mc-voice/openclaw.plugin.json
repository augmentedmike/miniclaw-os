{
  "id": "mc-voice",
  "name": "Miniclaw Voice",
  "description": "Captures human messages from all channels (Telegram, inbox, Claude Code) into voice.db with Gemini embeddings.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "humanId": { "type": "string", "description": "Human identifier (default: augmentedmike)" },
      "dbPath": { "type": "string", "description": "Path to voice.db (default: ~/.openclaw/USER/voice/voice.db)" },
      "ingestBin": { "type": "string", "description": "Path to voice-ingest script (default: ~/.openclaw/miniclaw/system/bin/voice-ingest)" }
    }
  }
}
